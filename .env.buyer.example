# Copy to `.env.buyer` for `npm run build:buyer` / `npm run apk:buyer`.
# Capacitor Android/iOS buyer packages load this mode.

VITE_APP_ROLE=buyer
VITE_BASE_PATH=/
VITE_API_BASE_URL=https://testapi.candlestack.site/api

VITE_GOOGLE_MAPS_API_KEY=

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
# Web Push certificate key from Firebase Console → Project settings → Cloud Messaging
VITE_FIREBASE_VAPID_KEY=
